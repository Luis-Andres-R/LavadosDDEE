rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email.lower() in ['oossdespachocargasqm@gmail.com', 'luis.robles.ramirez@gmail.com']
      );
    }

    function isOperator() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'operator') ||
        request.auth.token.email.lower() == 'lavadosddee@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'displayName', 'active']) &&
             data.keys().size() >= 4 && data.keys().size() <= 6 &&
             data.email is string && data.email.size() <= 128 &&
             data.role in ['admin', 'operator'] &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.active is bool;
    }

    function isValidDefaultWashing(data) {
      return data.keys().hasAll(['line', 'segmentName', 'defaultQuantity', 'active', 'createdAt', 'createdBy', 'updatedAt']) &&
             data.line in ['110 kV', '33 kV', '23 kV', '6,6 kV'] &&
             data.segmentName is string && data.segmentName.size() <= 200 &&
             data.defaultQuantity is number &&
             data.active is bool &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidWashingProgram(data) {
      return data.keys().hasAll(['date', 'shift', 'line', 'washingName', 'programmedQuantity', 'type', 'status', 'closed', 'createdAt', 'createdBy', 'updatedAt']) &&
             data.date is string &&
             data.shift in ['T39', 'T44'] &&
             data.line in ['110 kV', '33 kV', '23 kV', '6,6 kV'] &&
             data.washingName is string &&
             data.programmedQuantity is number && data.programmedQuantity > 0 &&
             data.type in ['Equipos críticos', 'Planta', 'Periferia'] &&
             data.status in ['Pendiente', 'Completo', 'Parcial', 'No realizado', 'Cerrado'] &&
             data.closed is bool &&
             data.createdAt == request.time &&
             data.updatedAt == request.time &&
             // Allow optional or extra fields without strict total key count
             (data.get('adminObservation', '') is string) &&
             (data.get('washingOperator', '') is string) &&
             (data.get('truck', '') is string);
    }

    function isValidWashingRecord(data) {
      return data.keys().hasAll(['programId', 'operatorEmail', 'status', 'programmedQuantity', 'completed', 'pending', 'percentage', 'registeredAt', 'updatedAt', 'syncStatus']) &&
             isValidId(data.programId) &&
             data.operatorEmail == request.auth.token.email &&
             data.status in ['Completo', 'Parcial', 'No realizado'] &&
             data.completed is number && data.pending is number &&
             data.completed + data.pending == data.programmedQuantity &&
             data.registeredAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidOperationalReading(data) {
      return data.keys().hasAll(['date', 'shift', 'operatorEmail', 'washingOperator', 'truck', 'readings', 'createdAt', 'updatedAt']) &&
             data.date is string &&
             data.shift in ['T39', 'T44'] &&
             data.readings is map &&
             data.readings.TKA.us is number &&
             data.readings.TKC.us is number &&
             data.readings.TKD.us is number &&
             data.readings.potableWater.us is number &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidOperatingHours(data) {
      return data.keys().hasAll(['date', 'shift', 'truck', 'operatorEmail', 'washingOperator', 'theoreticalHours', 'operationalHours', 'deductedHours', 'failureDetectedAt', 'reason', 'detail', 'createdAt', 'updatedAt']) &&
             data.date is string &&
             data.theoreticalHours is number &&
             data.operationalHours is number &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidTruck(data) {
      return data.keys().hasAll(['code', 'status', 'active', 'updatedAt', 'updatedBy']) &&
             data.code is string &&
             data.status in ['En servicio', 'Fuera de servicio', 'Disponible'] &&
             data.active is bool &&
             data.updatedBy is string;
    }

    function isValidTruckStatusHistory(data) {
      return data.keys().hasAll(['date', 'shift', 'trucks', 'savedAt', 'savedBy']) &&
             data.date is string &&
             data.shift in ['T39', 'T44'] &&
             data.trucks is list &&
             data.savedAt == request.time &&
             data.savedBy is string;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if (isAdmin() || isOwner(userId)) && isValidUser(incoming());
      allow update: if (isAdmin() && isValidUser(incoming())) ||
                     (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName']));
    }

    match /defaultWashings/{washingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /washingPrograms/{programId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidWashingProgram(incoming());
      allow update: if (isAdmin() && isValidWashingProgram(incoming())) ||
                     (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'completedCount', 'pendingCount', 'percentage', 'lastUpdatedBy', 'reason']) && !existing().closed);
      allow delete: if isAdmin();
    }

    match /washingRecords/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidWashingRecord(incoming()) && !get(/databases/$(database)/documents/washingPrograms/$(incoming().programId)).data.closed;
      allow update: if isSignedIn() && isValidWashingRecord(incoming()) && !get(/databases/$(database)/documents/washingPrograms/$(existing().programId)).data.closed;
    }

    match /changeHistory/{historyId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /operationalReadings/{readingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidOperationalReading(incoming());
      allow update: if isAdmin() && isValidOperationalReading(incoming());
    }

    match /truckOperatingHours/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidOperatingHours(incoming());
      allow update: if isAdmin() && isValidOperatingHours(incoming());
    }

    match /trucks/{truckId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidTruck(incoming());
    }

    match /truckStatusHistory/{historyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidTruckStatusHistory(incoming());
    }
  }
}

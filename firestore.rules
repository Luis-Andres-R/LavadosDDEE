rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default global deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Returns true if the user is one of the predefined accounts or marked active in users database
    function isActiveUser() {
      return isSignedIn() && (
        request.auth.token.email.lower() in [
          'oossdespachocargasqm@gmail.com',
          'lavadosddeet39@gmail.com',
          'lavadosddee@gmail.com',
          'luis.robles.ramirez@gmail.com'
        ] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true)
      );
    }

    // Returns true if the user is admin
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() in [
          'oossdespachocargasqm@gmail.com',
          'luis.robles.ramirez@gmail.com'
        ] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Returns true if the user is operator
    function isOperator() {
      return isSignedIn() && (
        request.auth.token.email.lower() in [
          'lavadosddeet39@gmail.com',
          'lavadosddee@gmail.com'
        ] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'operator')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rule Matches ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if (isAdmin() || isOwner(userId));
      allow delete: if isAdmin();
    }

    match /defaultWashings/{washingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /washingProgramTemplates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /washingPrograms/{programId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isActiveUser();
      allow update: if isAdmin() || (isActiveUser() && !resource.data.closed);
      allow delete: if isAdmin();
    }

    match /washingRecords/{recordId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isActiveUser();
      allow delete: if isAdmin();
    }

    match /changeHistory/{historyId} {
      allow read: if isAdmin() || isActiveUser();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /operationalReadings/{readingId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isActiveUser();
      allow delete: if isAdmin();
    }

    match /truckOperatingHours/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isActiveUser();
      allow delete: if isAdmin();
    }

    match /trucks/{truckId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /truckStatusHistory/{historyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /outOfProgramWashings/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isActiveUser();
      allow delete: if isAdmin();
    }

    // Paths/collections specifically requested or configured for version 2

    match /dailyWashingPrograms/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /records/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /records/programs/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /records/{id}/programs/{subId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /records/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /temperatures/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /conductivityReadings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }

    match /reports/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isActiveUser();
    }
  }
}
